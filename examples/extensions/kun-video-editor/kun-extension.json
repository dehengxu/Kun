{
  "$schema": "https://kun.dev/schemas/extensions/manifest/v1.json",
  "manifestVersion": 1,
  "apiVersion": "1.1.0",
  "name": "kun-video-editor",
  "publisher": "kun-examples",
  "version": "0.3.0",
  "displayName": "Kun Video Editor",
  "description": "Local transcript-oriented editing for talking-head, interview, and podcast media.",
  "localizations": {
    "zh": {
      "displayName": "Kun 视频编辑器",
      "description": "面向口播、访谈和播客媒体的本地转录文本剪辑工具。",
      "contributes": {
        "commands": {
          "editor-request": {
            "title": "视频编辑器请求",
            "category": "视频",
            "description": "Kun 视频编辑器视图使用的私有、有边界的 RPC。"
          }
        },
        "views.rightSidebar": {
          "editor": { "title": "Kun 视频编辑器" }
        },
        "message.resultPreviews": {
          "render-preview": { "title": "视频渲染结果" }
        },
        "settings": {
          "video-editor": {
            "title": "Kun 视频编辑器",
            "properties": {
              "defaultRenderPreset": {
                "title": "默认渲染预设",
                "description": "新渲染任务使用的默认类型。"
              },
              "defaultCaptionMode": {
                "title": "默认字幕模式",
                "description": "媒体渲染任务默认使用的字幕处理方式。"
              },
              "localTranscriber": {
                "title": "本地转录器",
                "description": "仅使用本地 ASR；没有可用的本地 Broker 时会明确报告不可用。"
              }
            }
          }
        },
        "agentProfiles": {
          "video-editor": {
            "title": "视频编辑器",
            "description": "用于口播、访谈和播客项目的私有本地转录文本剪辑 Agent。"
          }
        },
        "tools": {
          "video-project": {
            "description": "解析当前项目、列出项目、以只读方式获取项目，或显式创建、选择工作区中的权威项目。任何编辑前都必须读取当前版本。"
          },
          "video-probe": {
            "description": "导入或检测由 Host 授权的媒体句柄，持久化规范化的素材元数据，并可选请求缩略图或波形任务。绝不接受文件路径。"
          },
          "video-transcribe": {
            "description": "为素材导入有边界的带时间戳逐字稿；本地 ASR 不可用时如实报告，不编造文本，也不上传媒体。"
          },
          "video-read-script": {
            "description": "读取与确定版本绑定的 timeline.md 投影，用于逐字稿优先的审阅。"
          },
          "video-apply-script": {
            "description": "对未变更且绑定版本的 timeline.md 投影，作为单个事务应用明确的带时间源范围 Agent 剪辑。"
          },
          "video-update-timeline": {
            "description": "在预期版本上应用有边界的类型化时间线、字幕、变换、轨道放置或画布操作。"
          },
          "video-render": {
            "description": "启动由 Broker 持久处理的校样、预览、音频或 H.264 导出任务；可选烧录字幕及导出 SRT/VTT 外挂字幕，并绑定项目版本和不透明输出授权。"
          },
          "video-render-status": {
            "description": "无副作用地读取一个自有持久化渲染任务，仅返回与项目匹配且已通过技术校验的生成产物。"
          },
          "video-render-cancel": {
            "description": "验证可选的项目身份后，取消一个自有、受跟踪的持久化视频渲染任务。"
          }
        }
      }
    }
  },
  "license": "MIT",
  "engines": { "kun": ">=0.1.0" },
  "main": "dist/host/extension.js",
  "browser": "dist/webview/index.html",
  "activationEvents": [
    "onView:editor",
    "onView:render-preview",
    "onCommand:editor-request",
    "onAgentProfile:video-editor",
    "onTool:video-project",
    "onTool:video-probe",
    "onTool:video-transcribe",
    "onTool:video-read-script",
    "onTool:video-apply-script",
    "onTool:video-update-timeline",
    "onTool:video-render",
    "onTool:video-render-status",
    "onTool:video-render-cancel"
  ],
  "contributes": {
    "commands": [
      {
        "id": "editor-request",
        "title": "Video Editor Request",
        "category": "Video",
        "description": "Private bounded RPC used by the Kun Video Editor View.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": [
                "project.list",
                "project.active",
                "project.get",
                "project.select",
                "project.create",
                "project.update",
                "project.undo",
                "project.redo",
                "script.read",
                "script.apply",
                "media.import",
                "media.reauthorize",
                "transcript.import",
                "render.list",
                "render.start",
                "render.status",
                "render.cancel"
              ]
            },
            "payload": { "type": "object" }
          },
          "required": ["action", "payload"],
          "additionalProperties": false
        },
        "outputSchema": {
          "type": "object",
          "properties": {
            "content": {},
            "summary": { "type": "string" },
            "metadata": { "type": "object" },
            "generatedArtifacts": { "type": "array" }
          },
          "required": ["content"],
          "additionalProperties": false
        }
      }
    ],
    "views.rightSidebar": [
      {
        "id": "editor",
        "title": "Kun Video Editor",
        "entry": "dist/webview/index.html",
        "icon": "assets/video-editor.svg",
        "localResourceRoots": ["dist/webview"]
      }
    ],
    "message.resultPreviews": [
      {
        "id": "render-preview",
        "title": "Video render",
        "entry": "dist/webview/index.html",
        "mimeTypes": ["video/mp4", "audio/mp4", "image/png", "application/x-subrip", "text/vtt"],
        "localResourceRoots": ["dist/webview"]
      }
    ],
    "settings": [
      {
        "id": "video-editor",
        "title": "Kun Video Editor",
        "scope": "workspace",
        "properties": {
          "defaultRenderPreset": {
            "type": "string",
            "enum": ["proof-frame", "preview", "h264-mp4", "audio-aac"],
            "default": "preview",
            "title": "Default render preset",
            "description": "Default render kind."
          },
          "defaultCaptionMode": {
            "type": "string",
            "enum": ["none", "burned", "sidecar", "both"],
            "default": "none",
            "title": "Default caption mode",
            "description": "Default caption behavior for brokered media renders."
          },
          "localTranscriber": {
            "type": "string",
            "enum": ["disabled", "whisper-cli"],
            "default": "disabled",
            "title": "Local transcriber",
            "description": "Local-only ASR preference. API v1.1 imports timed transcripts and reports unavailable when no supported local broker exists."
          }
        }
      }
    ],
    "agentProfiles": [
      {
        "id": "video-editor",
        "title": "Video Editor",
        "description": "Private local transcript-first editing Agent for talking-head, interview, and podcast projects.",
        "instructions": "You are the private Kun Video Editor Agent for local transcript-oriented editing of talking-head, interview, and podcast projects. Respond in the user's current language unless the user explicitly asks for another language.\n\nBefore writing, ask for or confirm the creative goal, audience, target duration, aspect ratio, caption preference, and whether the user wants a review checkpoint or an export.\n\nFirst call video-project with action active to resolve the project currently selected in the right-sidebar editor. If there is no active project, ask the user to select or create one. Call video-project with action select only when the user explicitly changes the active project. Then call video-project with action get and video-read-script to read the current revision before a mutation. Treat revision conflicts as a request to refresh; never guess a merge.\n\nEdit structure first: remove only explicitly identified timed ranges, order the story, and keep source media immutable. Add captions, composition, or decoration only when requested.\n\nDo not introduce unrequested music, B-roll, stock media, generative video or images, motion graphics, face tracking, or subject-aware reframing.\n\nThis MVP has transcript and timing evidence, not arbitrary visual-scene understanding. Never infer unseen actions or claim visual inspection from transcript text or a successful command.\n\nUse proof-frame or preview renders to create an inspectable review artifact. Distinguish FFmpeg/ffprobe technical validation from actual visual review, and report stale proof when the project revision changed.\n\nStop at an editable review checkpoint unless export was requested. For export, pin the current revision and preset, poll the durable job with the read-only video-render-status tool, and use video-render-cancel only for an explicit cancellation request. Surface cancellation or invalid artifacts honestly.\n\nProtected media import and save-target selection require a Kun desktop interaction unless the caller already supplies valid opaque handles. In headless mode, return interaction-required instead of choosing a path or fabricating approval.",
        "allowedTools": [
          "video-project",
          "video-probe",
          "video-transcribe",
          "video-read-script",
          "video-apply-script",
          "video-update-timeline",
          "video-render",
          "video-render-status",
          "video-render-cancel"
        ],
        "budget": {
          "maxTokens": 32768,
          "maxElapsedMs": 1800000,
          "maxModelRequests": 48,
          "maxToolInvocations": 96,
          "maxEvents": 4000
        },
        "visibility": "private"
      }
    ],
    "tools": [
      {
        "id": "video-project",
        "description": "Resolve the active project, list projects, purely read one project, or explicitly create/select the authoritative workspace project. Read the current revision before any edit.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "action": { "type": "string", "enum": ["active", "list", "get", "create", "select"] },
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "name": { "type": "string", "minLength": 1, "maxLength": 160 },
            "fps": { "type": "object" },
            "canvasPreset": { "type": "string", "enum": ["16:9", "9:16", "1:1"] },
            "expectedRevision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
          },
          "required": ["action"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "write",
        "idempotent": false,
        "maxOutputBytes": 262144
      },
      {
        "id": "video-probe",
        "description": "Import or probe one Host-granted media handle, persist normalized asset metadata, and optionally request thumbnail or waveform jobs. Never accepts paths.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "expectedRevision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "mediaHandleId": { "type": "string", "minLength": 16, "maxLength": 512, "pattern": "^[A-Za-z0-9_-]+$" },
            "assetId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "addToTimeline": { "type": "boolean" },
            "thumbnailOutputHandleId": { "type": "string", "minLength": 16, "maxLength": 512, "pattern": "^[A-Za-z0-9_-]+$" },
            "waveformOutputHandleId": { "type": "string", "minLength": 16, "maxLength": 512, "pattern": "^[A-Za-z0-9_-]+$" }
          },
          "required": ["projectId", "expectedRevision"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "write",
        "idempotent": false,
        "maxOutputBytes": 131072
      },
      {
        "id": "video-transcribe",
        "description": "Import a bounded timed transcript into an asset, or report local-ASR capability as unavailable without inventing text or uploading media.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "expectedRevision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "assetId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "transcriptId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "mode": { "type": "string", "enum": ["import", "local-asr"] },
            "format": { "type": "string", "enum": ["srt", "vtt", "json"] },
            "language": { "type": "string", "minLength": 1, "maxLength": 32 },
            "source": { "type": "string", "minLength": 1, "maxLength": 524288 },
            "segments": { "type": "array", "minItems": 1, "maxItems": 20000, "items": { "type": "object" } }
          },
          "required": ["projectId", "expectedRevision", "assetId", "transcriptId", "mode"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "write",
        "idempotent": false,
        "maxOutputBytes": 131072
      },
      {
        "id": "video-read-script",
        "description": "Read the deterministic revision-bound timeline.md projection for transcript-first review.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "expectedRevision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
          },
          "required": ["projectId"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "read",
        "idempotent": true,
        "maxOutputBytes": 262144
      },
      {
        "id": "video-apply-script",
        "description": "Apply explicit timed source ranges from an unchanged revision-bound timeline.md projection as one transactional Agent edit.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "expectedRevision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "timelineMarkdown": { "type": "string", "minLength": 1, "maxLength": 262144 },
            "ranges": { "type": "array", "minItems": 1, "maxItems": 2000, "items": { "type": "object" } },
            "summary": { "type": "string", "minLength": 1, "maxLength": 512 }
          },
          "required": ["projectId", "expectedRevision", "timelineMarkdown", "ranges"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "destructive",
        "idempotent": false,
        "maxOutputBytes": 131072
      },
      {
        "id": "video-update-timeline",
        "description": "Apply bounded typed timeline, caption, transform, track-placement, or canvas operations at an expected revision.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "expectedRevision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "operations": { "type": "array", "minItems": 1, "maxItems": 200, "items": { "type": "object" } },
            "summary": { "type": "string", "minLength": 1, "maxLength": 512 }
          },
          "required": ["projectId", "expectedRevision", "operations"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "write",
        "idempotent": false,
        "maxOutputBytes": 131072
      },
      {
        "id": "video-render",
        "description": "Start a durable brokered proof, preview, audio, or H.264 export job, optionally with burned and SRT/VTT sidecar captions, pinned to a project revision and opaque output grants.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "expectedRevision": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
                "kind": { "type": "string", "enum": ["proof-frame", "preview", "h264-mp4", "audio-aac", "subtitles"] },
            "outputHandleId": { "type": "string", "minLength": 16, "maxLength": 512, "pattern": "^[A-Za-z0-9_-]+$" },
            "proofFrame": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
            "captionMode": { "type": "string", "enum": ["none", "burned", "sidecar", "both"] },
            "subtitleOutputHandleId": { "type": "string", "minLength": 16, "maxLength": 512, "pattern": "^[A-Za-z0-9_-]+$" },
            "subtitleFormat": { "type": "string", "enum": ["srt", "vtt"] },
            "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 256 }
          },
          "required": ["projectId", "expectedRevision", "kind"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "write",
        "idempotent": false,
        "maxOutputBytes": 131072
      },
      {
        "id": "video-render-status",
        "description": "Read one owned durable render job without side effects and return only project-matched, technically validated generated artifacts.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "jobId": { "type": "string", "minLength": 8, "maxLength": 512 },
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" }
          },
          "required": ["jobId"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "read",
        "idempotent": true,
        "maxOutputBytes": 131072
      },
      {
        "id": "video-render-cancel",
        "description": "Cancel one owned, tracked durable video render after verifying its optional project identity.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "jobId": { "type": "string", "minLength": 8, "maxLength": 512 },
            "projectId": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9][A-Za-z0-9._~-]{0,127}$" },
            "reason": { "type": "string", "minLength": 1, "maxLength": 512 }
          },
          "required": ["jobId"],
          "additionalProperties": false
        },
        "outputSchema": { "type": "object", "properties": { "outcome": { "type": "string", "minLength": 1, "maxLength": 64 } }, "required": ["outcome"], "additionalProperties": true },
        "sideEffects": "destructive",
        "idempotent": false,
        "maxOutputBytes": 131072
      }
    ]
  },
  "permissions": [
    "commands.register",
    "ui.views",
    "ui.actions",
    "webview",
    "agent.run",
    "tools.register",
    "storage.workspace",
    "workspace.read",
    "workspace.write",
    "media.read",
    "media.process",
    "media.export",
    "jobs.manage"
  ],
  "stateSchemaVersion": 1
}
